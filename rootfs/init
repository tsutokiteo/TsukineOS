#!/bin/sh

# 挂载虚拟文件系统
/bin/busybox mount -t proc none /proc
/bin/busybox mount -t sysfs none /sys
/bin/busybox mount -t devtmpfs none /dev

# 设置默认主机名
if [ ! -f /etc/hostname ]; then
    echo "tsukine" > /etc/hostname
fi
/bin/busybox hostname -F /etc/hostname

# 创建 /dev/null（如果不存在）
if [ ! -e /dev/null ]; then
    /bin/busybox mknod /dev/null c 1 3
    /bin/busybox chmod 666 /dev/null
fi

# 打印 Logo
/bin/busybox echo -e "\033c"
/bin/busybox echo "       .#####"
/bin/busybox echo "     ##@@@@@@"
/bin/busybox echo "    #@@@@@@"
/bin/busybox echo "   #@@@@@@"
/bin/busybox echo "   #@@@@@@@"
/bin/busybox echo "    #@@@@@@@"
/bin/busybox echo "     ##@@@@@@@"
/bin/busybox echo "       .#######"
/bin/busybox echo ""
/bin/busybox echo "   Welcome to TsukineOS!"
/bin/busybox echo "   Version: TsukineOS Indev"
/bin/busybox echo "   Kernel: 6.6.0-custom"
/bin/busybox echo "========================="
/bin/busybox echo ""

while true; do
    /bin/login
    sleep 1
done

# 直接启动 root shell
exec /bin/busybox sh
